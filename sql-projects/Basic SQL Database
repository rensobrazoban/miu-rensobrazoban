CREATE TABLE cliente (
    id_cliente INT PRIMARY KEY AUTO_INCREMENT,
    name VARCHAR(40) NOT NULL,
    tipo_cliente VARCHAR(40),
    fecha_alta DATE,
    EIN VARCHAR(30),
    sede_social VARCHAR(40)
);

CREATE TABLE almacen (
    id_almacen INT PRIMARY KEY AUTO_INCREMENT,
    nombre_almacen VARCHAR(40),
    ciudad VARCHAR(40)
);

CREATE TABLE articulos (
    codigo_articulo INT PRIMARY KEY AUTO_INCREMENT,
    tipo VARCHAR(40),
    subtipo VARCHAR(40),
    color VARCHAR(40),
    precio_unitario DECIMAL(10,2),
    impuesto DECIMAL(5,2)
);

CREATE TABLE pedidos (
    id_pedido INT PRIMARY KEY AUTO_INCREMENT,
    id_cliente INT,
    fecha_pedido DATE,
    fecha_recepcion DATE,
    fecha_entrega DATE,
    estado_pedido VARCHAR(40),
    estado_envio VARCHAR(40),
    id_almacen INT,

    FOREIGN KEY (id_cliente) REFERENCES cliente(id_cliente),
    FOREIGN KEY (id_almacen) REFERENCES almacen(id_almacen)
);

CREATE TABLE factura (
    id_factura INT PRIMARY KEY AUTO_INCREMENT,
    id_pedido INT,
    fecha_factura DATE,
    total_sin_impuesto DECIMAL(10,2),

    FOREIGN KEY (id_pedido) REFERENCES pedidos(id_pedido)
);

CREATE TABLE DetalleFactura (
    id_detalle INT PRIMARY KEY AUTO_INCREMENT,
    id_factura INT,
    codigo_articulo INT,
    cantidad INT,
    precio_unitario DECIMAL(10,2),

    FOREIGN KEY (id_factura) REFERENCES factura(id_factura),
    FOREIGN KEY (codigo_articulo) REFERENCES articulos(codigo_articulo)
);

