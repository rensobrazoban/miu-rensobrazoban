--Consulta 01
SELECT name, fecha_alta
FROM cliente
WHERE tipo_cliente = 'empresa'
ORDER BY fecha_alta;

--Consulta 02
SELECT EIN, sede_social
FROM cliente
WHERE tipo_cliente = 'empresa'
  AND name LIKE '%LLC%'
  AND fecha_alta BETWEEN '2005-01-01' AND '2017-12-31';

--Conulta 03
SELECT
  codigo_articulo,
  subtipo,
  precio_unitario,
  precio_unitario * (1 + impuesto) AS precio_con_impuesto
FROM articulos
WHERE color IN ('verde', 'gris', 'negro');

--Conulta 04
SELECT
  AVG(precio_unitario) AS promedio,
  MAX(precio_unitario) AS maximo,
  MIN(precio_unitario) AS minimo
FROM articulos
WHERE tipo = 'zapatilla';

--Conulta 05
SELECT
  c.id_cliente,
  c.name,
  COUNT(f.id_factura) AS total_facturas
FROM cliente c
LEFT JOIN pedidos p ON p.id_cliente = c.id_cliente
LEFT JOIN factura f ON f.id_pedido = p.id_pedido
GROUP BY c.id_cliente, c.name
ORDER BY total_facturas DESC;

--Conulta 06
SELECT
  f.id_factura,
  p.fecha_pedido,
  a.nombre_almacen,
  c.tipo_cliente,
  c.sede_social
FROM pedidos p
LEFT JOIN factura f ON f.id_pedido = p.id_pedido
JOIN cliente c ON c.id_cliente = p.id_cliente
JOIN almacen a ON a.id_almacen = p.id_almacen
WHERE p.estado_pedido = 'cancelado';

--Conulta 07
SELECT
  f.id_factura,
  DATEDIFF(p.fecha_entrega, p.fecha_recepcion) AS dias,
  a.ciudad,
  c.sede_social
FROM pedidos p
JOIN factura f ON f.id_pedido = p.id_pedido
JOIN cliente c ON c.id_cliente = p.id_cliente
JOIN almacen a ON a.id_almacen = p.id_almacen
WHERE p.estado_envio = 'enviado';

--Conulta 08
SELECT
  art.subtipo,
  SUM(df.cantidad) AS cantidad_total,
  SUM(df.cantidad * df.precio_unitario) AS monto_total
FROM factura f
JOIN DetalleFactura df ON df.id_factura = f.id_factura
JOIN articulos art ON art.codigo_articulo = df.codigo_articulo
WHERE f.fecha_factura BETWEEN '2019-01-01' AND '2019-12-31'
GROUP BY art.subtipo;

--Conulta 09
SELECT
  art.subtipo,
  SUM(df.cantidad) AS cantidad_total,
  SUM(df.cantidad * df.precio_unitario) AS monto_total
FROM factura f
JOIN DetalleFactura df ON df.id_factura = f.id_factura
JOIN articulos art ON art.codigo_articulo = df.codigo_articulo
WHERE f.fecha_factura BETWEEN '2019-01-01' AND '2019-12-31'
GROUP BY art.subtipo;

--Conulta EXTRA 01 

SELECT id_cliente, name, EIN
FROM cliente
WHERE EIN IS NULL OR EIN = '';

--Consulta EXTRA 02 

SELECT codigo_articulo, tipo, subtipo, precio_unitario
FROM articulos
ORDER BY precio_unitario DESC;

--Consulta EXTRA 03

SELECT estado_envio, COUNT(*) AS total_pedidos
FROM pedidos
GROUP BY estado_envio;

--Consulta EXTRA 04

SELECT
    c.id_cliente,
    c.name,
    SUM(f.total_sin_impuesto) AS total_gastado
FROM cliente c
JOIN pedidos p ON p.id_cliente = c.id_cliente
JOIN factura f ON f.id_pedido = p.id_pedido
GROUP BY c.id_cliente, c.name
ORDER BY total_gastado DESC;
